# Copy this file to .env.local and fill in real values.
# .env.local is already git-ignored - never commit real secrets.

# Supabase project settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Staff dashboard login (choose your own values)
STAFF_USERNAME=your-staff-username
STAFF_PASSWORD=a-strong-password

# Random secret used to sign staff session cookies.
# Generate one with: openssl rand -hex 32
STAFF_SESSION_SECRET=replace-with-a-long-random-string
